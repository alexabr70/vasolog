# fastlane/Fastfile
# encoding: utf-8
#
# Build name и build number уже записаны в pubspec.yaml workflow-ом (sed).
# Fastlane теперь только собирает и загружает - никакого авто-инкремента.

APP_STORE_CONNECT_API_KEY_PARAMS = {
  key_id:       ENV["ASC_KEY_ID"],
  issuer_id:    ENV["ASC_ISSUER_ID"],
  key_filepath: File.expand_path(
    "~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8"
  ),
  duration:     1200,
  in_house:     false
}.freeze

# ─── iOS ─────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Полный релиз в TestFlight"
  lane :release do
    api_key = app_store_connect_api_key(**APP_STORE_CONNECT_API_KEY_PARAMS)

    # 1. Синхронизируем сертификаты из match-repo (readonly).
    match(
      type:           "appstore",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      api_key:        api_key,
      readonly:       true
    )

    # 2. Сборка Flutter iOS IPA (версия уже в pubspec.yaml).
    # --obfuscate + --split-debug-info защищают Dart код от reverse engineering.
    # Символы сохраняются для crash reports (Crashlytics/App Store Connect).
    sh("cd .. && flutter build ipa --release --export-method=app-store --obfuscate --split-debug-info=./build/symbols")

    # 3. Загрузка в TestFlight.
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               Dir["../build/ios/ipa/*.ipa"].first,
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
      changelog:                         "Automated CI release"
    )

    UI.success("iOS build загружен в TestFlight")
  end

  desc "Одноразовый Bootstrap: создать Match сертификаты"
  lane :bootstrap_match do
    api_key = app_store_connect_api_key(**APP_STORE_CONNECT_API_KEY_PARAMS)
    match(
      type:                  "appstore",
      app_identifier:        ENV["IOS_BUNDLE_ID"],
      api_key:               api_key,
      readonly:              false,
      force_for_new_devices: true
    )
    match(
      type:           "development",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      api_key:        api_key,
      readonly:       false
    )
    UI.success("Match certificates готовы")
  end

end

# ─── Android ──────────────────────────────────────────────────────────────────

platform :android do

  desc "Полный релиз в Google Play"
  lane :release do
    package_name  = ENV["ANDROID_PACKAGE_NAME"]
    track         = ENV.fetch("RELEASE_TRACK", "internal")
    json_key_path = ENV.fetch("GOOGLE_PLAY_JSON_KEY_PATH")

    UI.user_error!("JSON key не найден: #{json_key_path}") unless File.exist?(json_key_path)

    # 1. Сборка Flutter Android AAB (версия уже в pubspec.yaml).
    sh("cd .. && flutter build appbundle --release --obfuscate --split-debug-info=./build/symbols")

    # 2. Загрузка в Play Console.
    upload_to_play_store(
      package_name:            package_name,
      aab:                     Dir["../build/app/outputs/bundle/release/*.aab"].first,
      track:                   track,
      json_key:                json_key_path,
      release_status:          track == "production" ? "completed" : "draft",
      skip_upload_apk:         true,
      skip_upload_metadata:    true,
      skip_upload_changelogs:  true,
      skip_upload_images:      true,
      skip_upload_screenshots: true
    )

    UI.success("Android build загружен в #{track}")
  end

end
