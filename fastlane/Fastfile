# fastlane/Fastfile
# encoding: utf-8

APP_STORE_CONNECT_API_KEY_PARAMS = {
  key_id:       ENV["ASC_KEY_ID"],
  issuer_id:    ENV["ASC_ISSUER_ID"],
  key_filepath: File.expand_path(
    "~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8"
  ),
  duration:     1200,
  in_house:     false
}.freeze

# ─── iOS ─────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Полный релиз в TestFlight"
  lane :release do
    api_key = app_store_connect_api_key(**APP_STORE_CONNECT_API_KEY_PARAMS)

    # 1. Синхронизируем сертификаты из vasolog-certs репо
    match(
      type:           "appstore",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      api_key:        api_key,
      readonly:       true
    )

    # 2. Автоинкремент build number через ASC API
    current_build = latest_testflight_build_number(
      api_key:              api_key,
      app_identifier:       ENV["IOS_BUNDLE_ID"],
      initial_build_number: 0
    )
    next_build = current_build + 1
    UI.message("Build number: #{current_build} → #{next_build}")

    update_pubspec_build_number(build_number: next_build)

    # 3. Сборка Flutter iOS
    sh("flutter build ipa --release --export-method=app-store")

    # 4. Загрузка в TestFlight
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               Dir["build/ios/ipa/*.ipa"].first,
      skip_waiting_for_build_processing: true,
      distribute_external:               false
    )

    UI.success("iOS build #{next_build} загружен в TestFlight")
  end

  desc "Одноразовый Bootstrap: создать Match сертификаты"
  lane :bootstrap_match do
    api_key = app_store_connect_api_key(**APP_STORE_CONNECT_API_KEY_PARAMS)
    match(
      type:                  "appstore",
      app_identifier:        ENV["IOS_BUNDLE_ID"],
      api_key:               api_key,
      readonly:              false,
      force_for_new_devices: true
    )
    match(
      type:           "development",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      api_key:        api_key,
      readonly:       false
    )
    UI.success("Match certificates готовы")
  end

end

# ─── Android ──────────────────────────────────────────────────────────────────

platform :android do

  desc "Полный релиз в Google Play"
  lane :release do
    package_name  = ENV["ANDROID_PACKAGE_NAME"]
    track         = ENV.fetch("RELEASE_TRACK", "internal")
    json_key_path = "android/fastlane/google-play-key.json"

    # 1. Автоинкремент version code через Play API
    begin
      codes = google_play_track_version_codes(
        package_name: package_name,
        track:        "internal",
        json_key:     json_key_path
      )
      next_code = (codes.max || 0) + 1
    rescue => e
      UI.message("Первый релиз, version code = 1: #{e.message}")
      next_code = 1
    end
    UI.message("Version code → #{next_code}")

    update_pubspec_build_number(build_number: next_code)

    # 2. Сборка Flutter Android AAB
    sh("flutter build appbundle --release")

    # 3. Загрузка в Play Console
    upload_to_play_store(
      package_name:            package_name,
      aab:                     Dir["build/app/outputs/bundle/release/*.aab"].first,
      track:                   track,
      json_key:                json_key_path,
      release_status:          track == "production" ? "completed" : "draft",
      skip_upload_apk:         true,
      skip_upload_images:      true,
      skip_upload_screenshots: true
    )

    UI.success("Android build #{next_code} загружен в #{track}")
  end

end

# ─── Private helpers ──────────────────────────────────────────────────────────

private_lane :update_pubspec_build_number do |options|
  build_number = options[:build_number]
  pubspec_path = File.expand_path("../pubspec.yaml")
  content      = File.read(pubspec_path)

  updated = content.gsub(
    /^version:\s*(\d+\.\d+\.\d+)\+\d+/,
    "version: \\1+#{build_number}"
  )

  UI.user_error!("pubspec.yaml: формат version не найден") if updated == content
  File.write(pubspec_path, updated)
  UI.message("pubspec.yaml: build number обновлён до #{build_number}")
end
