# AppGallery Connect API credentials
.env.agc
# HMS конфиг содержит client_secret - не коммитить
android/app/agconnect-services.json

# Android Developer Verification (ADI) token - sensitive
android/app/src/main/assets/adi-registration.properties

# Auto-generated build reports
android/build/reports/

# Signing
*.jks
*.keystore
android/key.properties

# Firebase service account (приватный ключ - никогда в git)
firebase-service-account.json
*-service-account.json

# Serena MCP
.serena/

# AppGallery upload artifacts (derivatives of mockups_final/)
release/*/store_assets/appgallery/upload_packages/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Testing artifacts (локальные скрины с устройства, отчёты Maestro/monkey/fastbot)
/screenshots/
/maestro-reports/
/maestro-artifacts/
/fastbot-output/
monkey-output.txt
logcat.txt
docs/aso/secrets/

# Release artifacts (тяжелые бинарники - не хранить в git)
release/v*/artifacts/
release/v*/assets/feature_graphics/
release/v*/*.apk
release/v*/*.aab
release/v*/*.ipa
release/v*/**/*.apk
release/v*/**/*.aab
release/v*/**/*.ipa
scripts/publishing/.tmp/

# Node dependencies (только scripts использует Node)
scripts/node_modules/
scripts/package-lock.json
MEMORY.md
release/*/store_assets/**/raw.bak/
release/*/store_assets/**/mockups_v2/
release/*/store_assets/**/mockups_v3/
release/*/store_assets/**/mockups_v4/
release/*/store_assets/**/mockups_v5/
# Скриншоты Google Play (v1.1.3) - тяжёлые, регенерируются из mockups + crop_v5.py
release/v1.1.3/store_assets/google_play/screenshots/
